# Flask PBIX API (must match ./scripts/run_flask_dashboard.sh printed port)
FLASK_URL=http://127.0.0.1:5052
NEXT_PUBLIC_FLASK_URL=http://127.0.0.1:5052

# Ollama OpenAI-compatible endpoint (no API key required)
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2:3b

# Documentation PDF (Ollama /api/generate) — defaults to qwen2.5:7b if unset
# DOC_PDF_OLLAMA_MODEL=qwen2.5:7b

# DAX: verbose browser console (console.debug for every SSE event)
# NEXT_PUBLIC_DAX_DEBUG=1
